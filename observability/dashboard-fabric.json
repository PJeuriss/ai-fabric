{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "AI Fabric Overview",
  "tags": ["ai-fabric"],
  "time": { "from": "now-30m", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "type": "timeseries",
      "title": "Fabric link utilization (out-octets rate)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(fabric_if_counters_out_octets[1m]) * 8",
          "legendFormat": "{{source}} {{interface_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bps" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Fabric link discards (out)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "rate(fabric_if_counters_out_discarded_packets[1m])",
          "legendFormat": "{{source}} {{interface_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "pps" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "Inference request latency (EPP p50/p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(mock_vllm_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(mock_vllm_request_latency_seconds_bucket[1m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "type": "timeseries",
      "title": "mock-vLLM queue depth by pod",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "mock_vllm_num_requests_waiting",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "type": "stat",
      "title": "Fabric-aware routes chosen (share)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(fabric_scorer_selected_total[5m])) / sum(rate(fabric_scorer_scored_total[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    }
  ]
}
