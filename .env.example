# Copy to .env and adjust. Sourced by scripts/lib.sh.

# ---- cluster ----
CLUSTER_NAME=ai-fabric
# number of REAL kind worker nodes (host actual pods: EPP, mock-vLLM, controllers)
KIND_WORKERS=2

# ---- simulated GPU fleet (KWOK) ----
GPU_NODES=200            # how many simulated GPU nodes to create
GPUS_PER_NODE=8          # advertised nvidia.com/gpu per simulated node
GPU_PRODUCT=NVIDIA-H100-80GB-HBM3

# ---- fabric topology (containerlab) ----
# leaf/spine sizing. Keep modest to save RAM (SR Linux ~1.5-2GB/node).
FABRIC_SPINES=2
FABRIC_LEAVES=4
FABRIC_NOS=srl           # srl (Nokia SR Linux, rich telemetry) | frr (ultralight)
SRL_IMAGE=ghcr.io/nokia/srlinux:24.10.1
FRR_IMAGE=quay.io/frrouting/frr:10.2.1

# ---- pinned tool versions (host-prep) ----
KIND_VERSION=v0.30.0
KWOK_VERSION=v0.7.0
CLAB_VERSION=0.60.0
GNMIC_VERSION=0.42.0
HELM_VERSION=v3.16.3
KUBECTL_VERSION=v1.31.0
GO_VERSION=1.23.4

# ---- component images (built locally, loaded into kind) ----
MOCK_VLLM_IMAGE=ai-fabric/mock-vllm:dev
FSS_IMAGE=ai-fabric/fabric-state-service:dev
EPP_IMAGE=ai-fabric/llm-d-epp-fabric:dev

# ---- llm-d / inference ----
GATEWAY_API_VERSION=v1.2.1
GIE_VERSION=v0.3.0                 # gateway-api-inference-extension (InferencePool CRD + EPP)
ENVOY_GATEWAY_VERSION=v1.2.1
# EPP base image (Phase D baseline). Phase E replaces it with our fabric image.
EPP_BASE_IMAGE=registry.k8s.io/gateway-api-inference-extension/epp:v0.3.0
# how many mock-vLLM serving pods (each pinned to a simulated GPU/fabric node)
MOCK_REPLICAS=6
# the reference "source" fabric node used for network-distance scoring
INGRESS_NODE=gpu-0001

# ---- training (Phase F) ----
KUEUE_VERSION=v0.9.1
JOBSET_VERSION=v0.7.2
TRAIN_JOBS=8              # number of gang training jobs to launch
TRAIN_WORKERS=4          # workers (GPU pods) per gang job
SYNTH_BPS_PER_POD=12000000000   # synthetic fabric load per training pod on a leaf

# ---- namespaces ----
NS_SYSTEM=ai-fabric-system
NS_INFER=llm-d
NS_MONITORING=monitoring
NS_TRAIN=training
